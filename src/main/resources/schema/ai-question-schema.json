{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI 出题返回结构约束",
  "description": "约束 Kimi API 出题接口的返回 JSON 格式，用于运行时校验，降低格式解析失败率",
  "type": "object",
  "required": ["questions"],
  "properties": {
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "type", "difficulty", "analysis"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "description": "题目内容"
          },
          "type": {
            "type": "string",
            "enum": ["CHOICE", "JUDGE", "TEXT"],
            "description": "题目类型"
          },
          "multi": {
            "type": "boolean",
            "description": "是否多选题（CHOICE 类型专用）"
          },
          "difficulty": {
            "type": "string",
            "enum": ["EASY", "MEDIUM", "HARD"],
            "description": "难度等级"
          },
          "score": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "description": "题目分值"
          },
          "choices": {
            "type": "array",
            "minItems": 2,
            "description": "选择题选项列表（CHOICE 类型必填）",
            "items": {
              "type": "object",
              "required": ["content", "isCorrect"],
              "properties": {
                "content": {
                  "type": "string",
                  "minLength": 1
                },
                "isCorrect": {
                  "type": "boolean"
                },
                "sort": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          },
          "answer": {
            "type": "string",
            "description": "判断题答案（TRUE/FALSE）或简答题参考答案"
          },
          "analysis": {
            "type": "string",
            "minLength": 1,
            "description": "题目解析"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": { "type": { "const": "CHOICE" } }
            },
            "then": {
              "required": ["choices"]
            }
          }
        ]
      }
    }
  }
}
