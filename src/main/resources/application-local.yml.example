# ============================================================================
# application-local.yml.example —— 本地开发配置模板
# ============================================================================
# 使用方法：
#   1. 复制此文件为 application-local.yml
#   2. 填入你自己的配置值
#   3. application-local.yml 已在 .gitignore 中，不会被提交到 Git
#
# Spring Boot 自动加载：
#   application.yml 中的 spring.profiles.active: local 会自动加载此文件
# ============================================================================

# ---------- 数据库配置 ----------
spring:
  datasource:
    # MySQL 数据库用户名（默认 root）
    username: your_db_username
    # MySQL 数据库密码（默认 root）
    password: your_db_password

# ---------- Redis 配置 ----------
  data:
    redis:
      # Redis 服务器地址（默认 localhost）
      host: your_redis_host
      # Redis 端口（默认 6379）
      port: 6379
      # Redis 密码（如果没有设置密码，删除此行或留空）
      password: your_redis_password

# ---------- AI API 配置（DeepSeek / Kimi 等） ----------
kimi:
  api:
    # AI API Key，例如 DeepSeek 的 sk-xxx
    # 获取地址：https://platform.deepseek.com/
    api-key: your_api_key_here

# ---------- JWT 配置 ----------
jwt:
  # JWT 签名密钥（生产环境请使用足够长度的随机字符串）
  # 可以使用命令生成：openssl rand -base64 32
  secret: your_jwt_secret_here

# ---------- MinIO 对象存储配置 ----------
minio:
  # MinIO 服务端点
  endpoint: http://your_minio_host:9000
  # MinIO 访问密钥
  access-key: your_minio_access_key
  # MinIO 密钥
  secret-key: your_minio_secret_key
